{
  "name": "velocity-dl",
  "private": true,
  "version": "0.3.5",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:deno": "deno compile --allow-all --output src-tauri/binaries/deno-engine-x86_64-pc-windows-msvc.exe src-deno/main.ts",
